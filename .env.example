# 飞书自建应用凭证（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格（首次启动可留空，程序会自动建表后回写到 data/config.json）
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_URL=
FEISHU_BITABLE_TABLE_NAME=主播复盘记录
FEISHU_BITABLE_BASE_NAME=主播复盘数据台

# 服务端口
PORT=3236

# 豆包视觉模型（火山引擎方舟）
# 留空则回退本地 tesseract OCR，准确率会差很多
# https://console.volcengine.com/ark
ARK_API_KEY=
ARK_MODEL_ID=
